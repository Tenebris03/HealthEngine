{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "backend": {
      "entry": ["src/main.ts"],
      "project": ["src/**/*.ts"]
    },
    "frontend": {
      "entry": ["src/main.tsx", "src/vite-env.d.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  },
  "ignoreDependencies": ["@commitlint/config-conventional"]
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int        @id @default(autoincrement())
  email           String     @unique
  name            String?
  avatar          String?
  passwordHash    String?
  provider        String
  providerId      String
  age             Int?
  heightCm        Float?
  targetWeightKg  Float?
  dailyCalorieGoal Int?
  points          Int        @default(0)
  createdAt       DateTime   @default(now())
  foodEntries     FoodEntry[]
  weightLogs      WeightLog[]
}

model FoodEntry {
  id          Int      @id @default(autoincrement())
  description String
  calories    Float
  protein     Float
  carbs       Float
  fat         Float
  mealType    String
  portion     Float    @default(1)
  createdAt   DateTime @default(now())
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id])
}

model WeightLog {
  id        Int      @id @default(autoincrement())
  weightKg  Float
  timestamp DateTime @default(now())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
}
